# ============================================================
# SalesGrowthPro Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# App
NEXT_PUBLIC_SITE_URL=https://salesgrowthpro.com

# Email (Choose one)
# Option 1: Resend
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_EMAIL=hello@salesgrowthpro.com

# Option 2: SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# Newsletter (Choose one)
# Option 1: Mailchimp
MAILCHIMP_API_KEY=xxxxxxxxxxxx-us1
MAILCHIMP_LIST_ID=xxxxxxxxxxxx

# Option 2: ConvertKit
# CONVERTKIT_API_KEY=xxxxxxxxxxxx
# CONVERTKIT_FORM_ID=xxxxxxxxxxxx

# Database (Choose one)
# Option 1: Supabase
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_ANON_KEY=xxxxxxxxxxxx

# Option 2: PlanetScale (MySQL)
# DATABASE_URL=mysql://xxxxxxxxxxxx

# Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_FB_PIXEL_ID=XXXXXXXXXX

# Webhook (Optional - for Zapier/Make)
# WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxxxxxxxxx/
